{
  "name": "ai-technical-debt-cli",
  "version": "1.0.1",
  "description": "Zero-dependency CLI for detecting and preventing AI-generated technical debt",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ai-debt": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^10.6.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "ai",
    "technical-debt",
    "code-quality",
    "cli",
    "audit",
    "typescript",
    "javascript"
  ],
  "author": "Sulthonzh",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
